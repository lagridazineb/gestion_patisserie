PORT=3001
NODE_ENV=development

# URL exacte de ton frontend en production (Render Static Site), utilisée pour restreindre le CORS.
# Ex: CLIENT_URL=https://dianna1.onrender.com
CLIENT_URL=

# Database — remplace par les identifiants de ta vraie base MySQL
# (locale en dev, ou fournie par Render/PlanetScale/Railway/etc. en prod)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=diana_pos
# Mets DB_SSL=true si ton hébergeur de base de données l'exige (souvent le cas en prod)
DB_SSL=false

# JWT — CHANGE cette valeur en production (chaîne aléatoire longue)
JWT_SECRET=change_moi_en_production
JWT_EXPIRES_IN=24h

# Bcrypt
BCRYPT_ROUNDS=10
